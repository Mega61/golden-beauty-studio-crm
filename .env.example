# Server
HOST=0.0.0.0
PORT=1337

# Database
# Use 'mysql' for MySQL or MariaDB, and change DATABASE_PORT to 3306
DATABASE_CLIENT=postgres
DATABASE_HOST=strapiDB
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi

# Secrets
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Environment
NODE_ENV=development

# Win-back
# Shared secret for the AgendaPro intake routes (POST /api/ingest/agendapro-report
# and /api/ingest/agendapro). The acquisition job sends it as the `x-ingest-secret`
# header. Generate a long random value; never commit the real one.
INGEST_SHARED_SECRET=
# Set to false to disable the daily recompute cron (config/cron.ts). Defaults to true.
# CRON_ENABLED=true

# Stampee fidelization integration (api-key). Cross-check runs after each report
# ingest; auto-issuing cards is OFF until STAMPEE_AUTOCREATE=true (review a dry-run
# first: POST /api/ingest/stampee-sync?dryRun=1). Leave blank to disable entirely.
STAMPEE_API_URL=https://api.loyalty.goldenbeautystudio.com.co
STAMPEE_API_KEY=
# Optional: pin the campaign to issue cards on (else auto-picks the enabled one).
# STAMPEE_CAMPAIGN_ID=
STAMPEE_AUTOCREATE=false
# Per-visit stamping: add one stamp per completed visit (first ever logged as
# "Primera visita", the rest "Visita recurrente"). OFF until STAMPEE_AUTOSTAMP=true —
# review a dry-run first: POST /api/ingest/stampee-sync?dryRun=1. Stamps stop at the
# campaign goal (manual redemption). The goal is read live from the campaign; this is the
# fallback used only if the API can't report it (current GBS campaign goal = 8).
STAMPEE_AUTOSTAMP=false
STAMPEE_STAMP_GOAL=8

# Reverse proxy
# Set to true in prod (behind Caddy/Nginx) so Strapi trusts X-Forwarded-* and
# sets Secure cookies correctly. Required for SSO OAuth callback to succeed.
IS_PROXIED=false

# Google SSO (admin panel) — strapi-plugin-sso
# Real values are injected at runtime in Portainer; never commit them.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override; defaults to the prod callback when unset.
# GOOGLE_OAUTH_REDIRECT_URI=https://cms.goldenbeautystudio.com.co/strapi-plugin-sso/google/callback
# Note: SSO is restricted to the goldenbeautystudio.com.co Workspace domain
# (GOOGLE_GSUITE_HD is hardcoded in config/plugins.ts — do not remove).