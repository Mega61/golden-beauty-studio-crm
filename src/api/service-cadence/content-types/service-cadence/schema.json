{
  "kind": "collectionType",
  "collectionName": "service_cadences",
  "info": {
    "singularName": "service-cadence",
    "pluralName": "service-cadences",
    "displayName": "Service Cadence",
    "description": "Per-category retoque window config (min/max days). Drives the win-back countdown."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "service_category": {
      "type": "enumeration",
      "enum": ["montaje", "retoque", "forrado", "sencillo", "press_on", "otro"],
      "required": true,
      "unique": true
    },
    "min_days": {
      "type": "integer",
      "default": 15
    },
    "max_days": {
      "type": "integer",
      "default": 21
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  }
}
